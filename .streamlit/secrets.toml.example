# これは「雛形」です。実際の secrets.toml は作成後 .gitignore で除外され、
# Streamlit Cloud では「App settings → Secrets」に同じ内容を貼り付けます。
# （秘密鍵を含むので絶対にGitHubへコミットしないこと）

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXX/edit"
worksheet = "cases"

# 以下は Google Cloud のサービスアカウントJSONの内容を転記する
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nXXXX...\n-----END PRIVATE KEY-----\n"
client_email = "equine-app@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/equine-app%40your-project-id.iam.gserviceaccount.com"
